# ─── Supabase (client-side) ───────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Etsy API (optional — add when ready) ────────────────────────────────────
VITE_ETSY_API_KEY=your-etsy-api-key

# ─── Slack Integration (Vercel server-side — NOT prefixed with VITE_) ────────
# These are only used by Vercel API Routes (api/*.js) and are never exposed
# to the browser bundle. Add them in your Vercel project's Environment Variables
# dashboard, NOT in .env.local.
#
# 1. Incoming Webhook URL — from Slack App → Incoming Webhooks → Add New Webhook
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# 2. Signing Secret — from Slack App → Basic Information → App Credentials
#    Used to verify that requests to /api/slack-commands and /api/slack-interactive
#    genuinely came from Slack (HMAC-SHA256 signature check).
SLACK_SIGNING_SECRET=your-slack-signing-secret

# 3. Supabase service-role key — from Supabase → Project Settings → API
#    Bypasses Row Level Security so the Slack API routes can write to the DB.
#    Keep this secret — never commit it or expose it client-side.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# 4. Supabase URL (server-side copy — same value as VITE_SUPABASE_URL)
SUPABASE_URL=https://your-project.supabase.co

# 5. Your deployed app URL — included as a "View in App" link in Slack messages
APP_URL=https://your-app.vercel.app
